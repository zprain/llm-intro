{
    "name": "Agentic Coding Dev Container (NVIDIA DGX)",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.11"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/docker-from-docker:2": {}
    },
    "remoteUser": "vscode",
    "workspaceFolder": "/workspace",
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "remoteEnv": {
        "WORKSPACE": "${containerWorkspaceFolder}",
        "PYTHONPYCACHEOFF": "1",
        "PIP_CACHE_DIR": "/tmp/pip-cache",
        "OLLAMA_HOST": "http://host.docker.internal:11434"
    },
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway"
    ],
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential jq curl wget git vim htop net-tools",
    "customizations": {
        "vscode": {
    "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "GitHub.vscode-github-actions",
        "ms-vscode.makefile-tools",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-ai",
        "cline.cline",
        "kilo-code.kilo-code"
    ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": true,
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "explicit"
                },
                "files.autoSave": "afterDelay",
                "files.eol": "\n",
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "terminal.integrated.fontSize": 14
            }
        }
    }
}